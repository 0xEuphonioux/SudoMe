#!/bin/bash
# SudoMe Helper — Polkit-backed privileged operations
# Called by polkitd when a client requests sudo grant/revoke/status.
# This script runs as root.
#
# Usage:
#   sudome-helper grant <username> <minutes> [reason]
#   sudome-helper revoke <username> [reason]
#   sudome-helper status <username>
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail

ACTION="${1:-}"
USERNAME="${2:-}"
ARG3="${3:-}"
ARG4="${4:-}"

# ── Configuration ──────────────────────────────────────────────────────
SUDO_GROUP="${SUDO_GROUP:-sudo}"
STATE_DIR="/var/lib/sudome"
LOG_TAG="sudome-helper"

# ── Logging ────────────────────────────────────────────────────────────
log() {
    local level="$1"; shift
    logger -t "$LOG_TAG" -p "auth.$level" "$*"
}

# ── Validate username ──────────────────────────────────────────────────
validate_user() {
    # Reject usernames with path separators or special characters
    # that could enable path traversal or command injection
    if [[ ! "$USERNAME" =~ ^[a-z_][a-z0-9_-]*$ ]]; then
        log err "Invalid username characters: '$USERNAME'"
        echo "ERROR: Invalid username '$USERNAME'. Only lowercase alphanumeric, dash, underscore allowed."
        exit 1
    fi
    if [[ "${#USERNAME}" -gt 32 ]]; then
        log err "Username too long: '$USERNAME'"
        echo "ERROR: Username too long."
        exit 1
    fi
    if ! id "$USERNAME" &>/dev/null; then
        log err "User '$USERNAME' does not exist"
        echo "ERROR: User '$USERNAME' does not exist"
        exit 1
    fi
}

# ── Send desktop notification (as the user, not root) ──────────────────
notify_user() {
    local username="$1"
    local title="$2"
    local message="$3"
    local urgency="${4:-normal}"
    
    # Send notification as the target user via their D-Bus session bus
    local uid
    uid=$(id -u "$username" 2>/dev/null) || return 0
    
    # Find the user's D-Bus session address
    local dbus_addr
    dbus_addr=$(cat "/run/user/${uid}/bus" 2>/dev/null || true)
    
    if [[ -n "$dbus_addr" ]] && command -v gdbus &>/dev/null; then
        local urg_val=1
        [[ "$urgency" == "critical" ]] && urg_val=2
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${uid}/bus" \
        gdbus call --session \
            --dest org.freedesktop.Notifications \
            --object-path /org/freedesktop/Notifications \
            --method org.freedesktop.Notifications.Notify \
            "sudome" 0 "sudome" "$title" "$message" \
            '[]' "{'urgency': <$urg_val>}" \
            -1 2>/dev/null || true
    fi
}

# ── Grant sudo ─────────────────────────────────────────────────────────
cmd_grant() {
    validate_user
    local minutes="${ARG3:-30}"
    local reason="${ARG4:-}"
    
    # Validate minutes is a positive integer (prevents shell/Python injection)
    if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [[ "$minutes" -lt 1 ]]; then
        log err "Invalid minutes value: '$minutes'"
        echo "ERROR: Invalid duration. Must be a positive integer."
        exit 1
    fi
    
    # Enforce max_duration from config
    if [[ -f "/etc/sudome/config.yaml" ]] && command -v python3 &>/dev/null; then
        local max_dur
        max_dur=$(python3 -c "
import yaml,sys
try:
    with open('/etc/sudome/config.yaml') as f:
        c = yaml.safe_load(f)
    print(c.get('max_duration', 0))
except: print(0)
" 2>/dev/null)
        if [[ "$max_dur" -gt 0 ]] && [[ "$minutes" -gt "$max_dur" ]]; then
            log err "Duration $minutes exceeds max_duration $max_dur"
            echo "ERROR: Maximum allowed duration is $max_dur minutes"
            exit 1
        fi
    fi

    # Check if already in sudo group
    if groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        echo "ALREADY_ACTIVE"
        log info "User '$USERNAME' already in sudo group"
        exit 0
    fi

    # Add to sudo group
    if usermod -a -G "$SUDO_GROUP" "$USERNAME" 2>/dev/null; then
        local expiry now_ts
        now_ts=$(date +%s 2>/dev/null || python3 -c "import time; print(int(time.time()))")
        expiry=$((now_ts + minutes * 60))

        # Persist expiry timestamp
        mkdir -p "$STATE_DIR"
        echo "$expiry" > "${STATE_DIR}/${USERNAME}.expiry"
        chmod 644 "${STATE_DIR}/${USERNAME}.expiry"

        # Write syslog audit event
        local now=$(date '+%m/%d/%Y %I:%M:%S %p')
        local log_msg="GRANT: user='$USERNAME' minutes=$minutes expiry=$expiry"
        if [[ -n "$reason" ]]; then
            log_msg="$log_msg reason='$reason'"
        fi
        log notice "$log_msg"

        # Structured event for SIEM (matching SAP Privileges format)
        local structured_msg="Process sudome created at $now by user $USERNAME in session $(loginctl list-sessions --no-legend 2>/dev/null | grep "$USERNAME" | awk '{print $1}' | head -1 || echo '?') with an elevation type of Default. action: 'grant' minutes: '$minutes'"
        if [[ -n "$reason" ]]; then
            structured_msg="$structured_msg reason: '$reason'"
        fi
        logger -t "$LOG_TAG" -p auth.notice "$structured_msg"

        # Desktop notification
        local notify_msg="You now have administrator privileges for ${minutes} minutes."
        if [[ -n "$reason" ]]; then
            notify_msg="${notify_msg} Reason: ${reason}"
        fi
        notify_user "$USERNAME" \
            "🔓 Administrator Privileges Granted" \
            "${notify_msg}" \
            "normal"

        echo "GRANTED $minutes $expiry"
    else
        log err "Failed to add '$USERNAME' to '$SUDO_GROUP' group"
        echo "ERROR: Failed to grant sudo access"
        exit 1
    fi
}

# ── Revoke sudo ────────────────────────────────────────────────────────
cmd_revoke() {
    validate_user
    local reason="${ARG3:-}"

    # Check if in sudo group
    if ! groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        echo "NOT_ACTIVE"
        log info "User '$USERNAME' not in sudo group — nothing to revoke"
        exit 0
    fi

    # Remove from sudo group
    if deluser "$USERNAME" "$SUDO_GROUP" 2>/dev/null || \
       gpasswd -d "$USERNAME" "$SUDO_GROUP" 2>/dev/null; then
        rm -f "${STATE_DIR}/${USERNAME}.expiry"

        local now=$(date '+%m/%d/%Y %I:%M:%S %p')
        local log_msg="REVOKE: user='$USERNAME'"
        if [[ -n "$reason" ]]; then
            log_msg="$log_msg reason='$reason'"
        fi
        log notice "$log_msg"

        logger -t "$LOG_TAG" -p auth.notice \
            "Administrator privileges have been revoked for user $USERNAME at $now."

        # Desktop notification
        local notify_msg="Your elevation has expired. You have been demoted back to a standard user."
        if [[ -n "$reason" ]]; then
            notify_msg="${notify_msg} (${reason})"
        fi
        notify_user "$USERNAME" \
            "🔒 Administrator Privileges Revoked" \
            "${notify_msg}" \
            "normal"

        echo "REVOKED"
    else
        log err "Failed to remove '$USERNAME' from '$SUDO_GROUP' group"
        echo "ERROR: Failed to revoke sudo access"
        exit 1
    fi
}

# ── Check status ───────────────────────────────────────────────────────
cmd_status() {
    validate_user

    if groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        if [[ -f "${STATE_DIR}/${USERNAME}.expiry" ]]; then
            local expiry
            expiry=$(cat "${STATE_DIR}/${USERNAME}.expiry")
            local now
            now=$(date +%s)
            local remaining=$((expiry - now))
            echo "ACTIVE $remaining $expiry"
        else
            echo "ACTIVE 0 0"
        fi
    else
        echo "NOT_ACTIVE"
    fi
}

# ── Renew sudo (extend existing grant) ─────────────────────────────────
cmd_renew() {
    validate_user
    local minutes="${ARG3:-30}"
    local reason="${ARG4:-}"
    
    # Validate minutes
    if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [[ "$minutes" -lt 1 ]]; then
        log err "Invalid minutes value: '$minutes'"
        echo "ERROR: Invalid duration. Must be a positive integer."
        exit 1
    fi

    # Check if currently active
    if ! groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        echo "NOT_ACTIVE"
        log info "User '$USERNAME' not in sudo group — cannot renew"
        exit 0
    fi

    # Extend expiry by adding minutes to current expiry (or now if file missing)
    mkdir -p "$STATE_DIR"
    local now_ts new_expiry
    now_ts=$(date +%s 2>/dev/null || python3 -c "import time; print(int(time.time()))")
    
    if [[ -f "${STATE_DIR}/${USERNAME}.expiry" ]]; then
        local current_expiry
        current_expiry=$(cat "${STATE_DIR}/${USERNAME}.expiry")
        if [[ "$current_expiry" -lt "$now_ts" ]]; then
            new_expiry=$((now_ts + minutes * 60))
        else
            new_expiry=$((current_expiry + minutes * 60))
        fi
    else
        new_expiry=$((now_ts + minutes * 60))
    fi
    
    echo "$new_expiry" > "${STATE_DIR}/${USERNAME}.expiry"
    chmod 644 "${STATE_DIR}/${USERNAME}.expiry"
    
    local log_msg="RENEW: user='$USERNAME' minutes=$minutes expiry=$new_expiry"
    if [[ -n "$reason" ]]; then
        log_msg="$log_msg reason='$reason'"
    fi
    log notice "$log_msg"
    
    echo "GRANTED $minutes $new_expiry"
}

# ── Main ───────────────────────────────────────────────────────────────
case "$ACTION" in
    grant)  cmd_grant ;;
    revoke) cmd_revoke ;;
    renew)  cmd_renew ;;
    status) cmd_status ;;
    *)
        echo "ERROR: Unknown action '$ACTION'. Use: grant|revoke|status <username> [minutes] [reason]"
        exit 1
        ;;
esac
