#!/bin/bash
# SudoMe Helper — Polkit-backed privileged operations
# Called by polkitd when a client requests sudo grant/revoke/status.
# This script runs as root.
#
# Usage:
#   sudome-helper grant <username> <minutes> [reason]
#   sudome-helper revoke <username> [reason]
#   sudome-helper renew <username> <minutes> [reason]
#   sudome-helper status <username>
#
# Enterprise features:
#   - Reason enforcement (required, min/max length, presets)
#   - Post-change actions (executables run after grant/revoke)
#   - Webhook callbacks (HTTP POST on state change)
#   - Atomic state file writes with flock
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail

ACTION="${1:-}"
USERNAME="${2:-}"
ARG3="${3:-}"
ARG4="${4:-}"

# ── Configuration ──────────────────────────────────────────────────────
SUDO_GROUP="${SUDO_GROUP:-sudo}"
STATE_DIR="/var/lib/sudome"
CONFIG_FILE="/etc/sudome/config.yaml"
LOG_TAG="sudome-helper"

# ── Logging ────────────────────────────────────────────────────────────
log() {
    local level="$1"; shift
    logger -t "$LOG_TAG" -p "auth.$level" "$*"
}

# ── Config reader (cached, supports policy override from SAP Privileges) ─
_CONFIG_FILE="/etc/sudome/config.yaml"
_POLICY_FILE="/etc/sudome/policy.yaml"
_config_cache=""

# Load merged config: policy.yaml overrides config.yaml
# Uses argument passing instead of string interpolation (SAFE against injection)
load_config() {
    _config_cache=""
    if [[ ! -f "$_CONFIG_FILE" ]]; then
        return
    fi
    if command -v python3 &>/dev/null; then
        _config_cache=$(python3 - "$_CONFIG_FILE" "$_POLICY_FILE" << 'PYEOF'
import sys, yaml

def load_yaml(path):
    try:
        with open(path) as f:
            return yaml.safe_load(f) or {}
    except Exception:
        return {}

config = load_yaml(sys.argv[1])

# Merge policy.yaml if it exists and was passed
if len(sys.argv) > 2 and sys.argv[2]:
    policy = load_yaml(sys.argv[2])
    config.update(policy)

for k, v in config.items():
    if isinstance(v, bool):
        print(f'{k}={str(v).lower()}')
    elif isinstance(v, list):
        vals = ' '.join(str(x) for x in v)
        print(f'{k}=({vals})')
    elif isinstance(v, dict):
        for dk, dv in v.items():
            if isinstance(dv, list):
                dvals = ' '.join(str(x) for x in dv)
                print(f'{k}.{dk}=({dvals})')
            elif dv is not None:
                print(f'{k}.{dk}={dv}')
    elif v is not None:
        print(f'{k}={v}')
PYEOF
    )
fi
}

get_config() {
    local key="$1"
    local default="${2:-}"
    if [[ -z "$_config_cache" ]]; then
        load_config
    fi
    local val
    val=$(echo "$_config_cache" | grep "^${key}=" | head -1 | cut -d= -f2-)
    if [[ -z "$val" ]]; then
        echo "$default"
    else
        echo "$val"
    fi
}

# ── Entity Authorization (SAP Privileges feature) ──────────────────────
# Check if user is in allowed list and not in denied list
check_allowed_denied() {
    local username="$1"
    
    # Get denied entities
    local denied
    denied=$(get_config "denied_entities" "")
    denied="${denied#\(}"; denied="${denied%\)}"
    
    # Check denied first (trumps allowed)
    for entity in $denied; do
        if [[ "$entity" == "$username" ]]; then
            log err "User '$username' is in denied_entities — access denied"
            echo "ERROR: You are not authorized to request sudo privileges."
            exit 1
        fi
        if [[ "$entity" =~ ^@ ]]; then
            local group="${entity#@}"
            if groups "$username" 2>/dev/null | grep -qw "$group"; then
                log err "User '$username' is in denied group '$group' — access denied"
                echo "ERROR: Your group is not authorized to request sudo privileges."
                exit 1
            fi
        fi
    done
    
    # Get allowed entities (if set, must be in list)
    local allowed
    allowed=$(get_config "allowed_entities" "")
    allowed="${allowed#\(}"; allowed="${allowed%\)}"
    
    if [[ -z "$allowed" ]]; then
        return 0  # No allow list — everyone allowed (after deny check)
    fi
    
    for entity in $allowed; do
        if [[ "$entity" == "$username" ]]; then
            return 0
        fi
        if [[ "$entity" =~ ^@ ]]; then
            local group="${entity#@}"
            if groups "$username" 2>/dev/null | grep -qw "$group"; then
                return 0
            fi
        fi
    done
    
    log err "User '$username' not in allowed_entities — access denied"
    echo "ERROR: You are not authorized to request sudo privileges."
    echo "Contact your system administrator for access."
    exit 1
}

# ── Per-User Timeout Override (MakeMeAdmin feature) ─────────────────────
get_user_timeout() {
    local username="$1"
    local default_minutes="$2"
    
    local overrides
    overrides=$(get_config "timeout_overrides" "")
    
    if [[ -z "$overrides" ]]; then
        echo "$default_minutes"
        return
    fi
    
    local max_override=0
    local entries
    # Parse the dict format: key1=val1 key2=val2 ...
    entries=$(echo "$_config_cache" | grep "^timeout_overrides\." | cut -d= -f1-)
    
    while IFS='=' read -r k v; do
        local entity="${k#timeout_overrides.}"
        entity="${entity#\(}"; entity="${entity%\)}"
        
        if [[ "$entity" == "$username" ]] && [[ "$v" -gt "$max_override" ]]; then
            max_override="$v"
        fi
        
        if [[ "$entity" =~ ^@ ]]; then
            local group="${entity#@}"
            if groups "$username" 2>/dev/null | grep -qw "$group" && [[ "$v" -gt "$max_override" ]]; then
                max_override="$v"
            fi
        fi
    done <<< "$entries"
    
    # Use the HIGHER of default and override (MakeMeAdmin behavior)
    if [[ "$max_override" -gt "$default_minutes" ]]; then
        echo "$max_override"
    else
        echo "$default_minutes"
    fi
}

# ── Renewal Limit Check (MakeMeAdmin feature) ───────────────────────────
check_renewal_limit() {
    local username="$1"
    local max_renewals
    max_renewals=$(get_config "max_renewals" "0")
    
    if [[ "$max_renewals" -eq 0 ]]; then
        return 0  # No limit
    fi
    
    local count_file="${STATE_DIR}/${username}.renewal_count"
    local current_count=0
    
    if [[ -f "$count_file" ]]; then
        current_count=$(cat "$count_file" 2>/dev/null || echo 0)
    fi
    
    if [[ "$current_count" -ge "$max_renewals" ]]; then
        log err "User '$username' has reached renewal limit ($max_renewals)"
        echo "ERROR: Maximum renewal count reached ($max_renewals). Request a new grant."
        exit 1
    fi
    
    return 0
}

increment_renewal_count() {
    local username="$1"
    local count_file="${STATE_DIR}/${username}.renewal_count"
    local current_count=0
    [[ -f "$count_file" ]] && current_count=$(cat "$count_file" 2>/dev/null || echo 0)
    echo $((current_count + 1)) > "$count_file"
}

clear_renewal_count() {
    local username="$1"
    rm -f "${STATE_DIR}/${username}.renewal_count"
}

# ── Validate username ──────────────────────────────────────────────────
validate_user() {
    if [[ ! "$USERNAME" =~ ^[a-z_][a-z0-9_-]*$ ]]; then
        log err "Invalid username characters: '$USERNAME'"
        echo "ERROR: Invalid username '$USERNAME'. Only lowercase alphanumeric, dash, underscore allowed."
        exit 1
    fi
    if [[ "${#USERNAME}" -gt 32 ]]; then
        log err "Username too long: '$USERNAME'"
        echo "ERROR: Username too long."
        exit 1
    fi
    if ! id "$USERNAME" &>/dev/null; then
        log err "User '$USERNAME' does not exist"
        echo "ERROR: User '$USERNAME' does not exist"
        exit 1
    fi
}

# ── Interactive reason prompt (runs AFTER pkexec auth, uses /dev/tty) ──
prompt_reason_interactive() {
    # Only works when a terminal is attached (pkexec from CLI preserves it)
    if [[ ! -c /dev/tty ]]; then
        echo "ERROR: Reason is required but no terminal available. Use -r flag or GUI." >&2
        exit 1
    fi
    local presets min_len strict reason choice
    presets=$(get_config "reason_presets" "")
    min_len=$(get_config "reason_min_length" "0")
    strict=$(get_config "reason_strict_presets" "false")
    reason=""
    
    # Strip parentheses from get_config list format
    presets="${presets#\(}"
    presets="${presets%\)}"
    
    echo "" > /dev/tty
    echo "  Reason required for administrator privileges:" > /dev/tty
    
    if [[ -n "$presets" ]]; then
        echo "" > /dev/tty
        local i=1
        for preset in $presets; do
            echo "    [$i] $preset" > /dev/tty
            ((i++))
        done
        if [[ "$strict" != "true" ]]; then
            echo "    [0] Enter custom reason" > /dev/tty
        fi
        echo "" > /dev/tty
        read -p "  Select [1-$((i-1))]: " choice < /dev/tty
        
        if [[ "$choice" =~ ^[0-9]+$ ]]; then
            local idx=1
            for preset in $presets; do
                if [[ "$choice" -eq "$idx" ]]; then
                    reason="$preset"
                    break
                fi
                ((idx++))
            done
        fi
        
        if [[ -z "$reason" ]] && [[ "$strict" == "true" ]]; then
            echo "ERROR: Invalid selection" > /dev/tty
            exit 1
        fi
    fi
    
    if [[ -z "$reason" ]]; then
        read -p "  Enter reason: " reason < /dev/tty
    fi
    
    if [[ -z "$reason" ]]; then
        echo "ERROR: Reason cannot be empty" > /dev/tty
        exit 1
    fi
    
    if [[ "$min_len" -gt 0 ]] && [[ "${#reason}" -lt "$min_len" ]]; then
        echo "ERROR: Reason must be at least $min_len characters (got ${#reason})" > /dev/tty
        exit 1
    fi
    
    echo "$reason"
}

# ── Reason validation ──────────────────────────────────────────────────
validate_reason() {
    local reason="$1"
    local require_reason
    require_reason=$(get_config "require_reason" "false")
    
    if [[ "$require_reason" != "true" ]] && [[ -z "$reason" ]]; then
        return 0  # Not required, not provided — OK
    fi
    
    if [[ "$require_reason" == "true" ]] && [[ -z "$reason" ]]; then
        log err "Reason required but not provided"
        echo "ERROR: A reason is required for this operation."
        exit 1
    fi
    
    if [[ -n "$reason" ]]; then
        local min_len max_len
        min_len=$(get_config "reason_min_length" "0")
        max_len=$(get_config "reason_max_length" "256")
        
        if [[ "${#reason}" -lt "$min_len" ]]; then
            log err "Reason too short: ${#reason} chars (min $min_len)"
            echo "ERROR: Reason must be at least $min_len characters."
            exit 1
        fi
        
        if [[ "${#reason}" -gt "$max_len" ]]; then
            log err "Reason too long: ${#reason} chars (max $max_len)"
            echo "ERROR: Reason must be at most $max_len characters."
            exit 1
        fi
        
        # Check presets if configured
        local presets
        presets=$(get_config "reason_presets" "")
        if [[ -n "$presets" ]]; then
            local strict
            strict=$(get_config "reason_strict_presets" "false")
            # presets are stored as (value1 value2 value3) from our config reader
            # Strip parentheses
            presets="${presets#\(}"
            presets="${presets%\)}"
            local found=false
            for preset in $presets; do
                if [[ "$preset" == "$reason" ]]; then
                    found=true
                    break
                fi
            done
            if [[ "$found" != "true" ]] && [[ "$strict" == "true" ]]; then
                log err "Reason not in preset list: '$reason'"
                echo "ERROR: Reason must be one of: $presets"
                exit 1
            fi
        fi
    fi
    return 0
}

# ── Atomic state file write ────────────────────────────────────────────
atomic_write() {
    local filepath="$1"
    local content="$2"
    local tmpfile="${filepath}.tmp.$$"
    echo "$content" > "$tmpfile"
    chmod 644 "$tmpfile"
    mv "$tmpfile" "$filepath"
}

# ── Post-change action ─────────────────────────────────────────────────
run_post_change_action() {
    local action="$1"   # grant or revoke
    local username="$2"
    local minutes="$3"
    local reason="$4"
    
    local executable checksum
    executable=$(get_config "post_change_executable" "")
    if [[ -z "$executable" ]]; then
        return 0  # Not configured — skip
    fi
    
    # Check grant-only flag
    local grant_only
    grant_only=$(get_config "post_change_action_on_grant_only" "false")
    if [[ "$grant_only" == "true" ]] && [[ "$action" != "grant" ]]; then
        return 0
    fi
    
    # Verify executable exists
    if [[ ! -x "$executable" ]]; then
        log err "Post-change executable not found or not executable: $executable"
        return 1
    fi
    
    # Checksum verification
    checksum=$(get_config "post_change_executable_checksum" "")
    if [[ -n "$checksum" ]] && command -v sha256sum &>/dev/null; then
        local actual
        actual=$(sha256sum "$executable" | cut -d' ' -f1)
        if [[ "$actual" != "$checksum" ]]; then
            log err "Post-change executable checksum mismatch: expected $checksum, got $actual"
            return 1
        fi
    fi
    
    # Build arguments
    local args=("$executable" "$action" "$username" "$minutes")
    local pass_reason
    pass_reason=$(get_config "pass_reason_to_executable" "true")
    if [[ "$pass_reason" == "true" ]] && [[ -n "$reason" ]]; then
        args+=("$reason")
    fi
    
    # Run (non-blocking, fire-and-forget)
    "${args[@]}" &
    log info "Post-change action triggered: $action for $username"
}

# ── Webhook ────────────────────────────────────────────────────────────
send_webhook() {
    local action="$1"
    local username="$2"
    local minutes="$3"
    local reason="$4"
    local expiry="${5:-0}"
    
    local webhook_url
    webhook_url=$(get_config "webhook_url" "")
    if [[ -z "$webhook_url" ]]; then
        return 0
    fi
    
    if ! command -v curl &>/dev/null; then
        log warn "curl not available — webhook disabled"
        return 0
    fi
    
    local timeout
    timeout=$(get_config "webhook_timeout" "10")
    
    local now_iso
    now_iso=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S%z')
    local hostname
    hostname=$(hostname 2>/dev/null || echo "unknown")
    
    # Build JSON payload
    local custom_json="{}"
    # Try to get custom_data from config
    if [[ -f "$CONFIG_FILE" ]] && command -v python3 &>/dev/null; then
        custom_json=$(python3 -c "
import yaml,json
try:
    with open('$CONFIG_FILE') as f:
        c = yaml.safe_load(f) or {}
    cd = c.get('webhook_custom_data', {})
    if cd:
        print(json.dumps(cd))
    else:
        print('{}')
except: print('{}')
" 2>/dev/null)
    fi
    
    local payload
    payload=$(python3 -c "
import json, sys
custom = json.loads('''$custom_json''')
payload = {
    'event': '$action',
    'username': '$username',
    'minutes': $minutes,
    'expiry': $expiry,
    'timestamp': '$now_iso',
    'hostname': '$hostname',
    'source': 'sudome',
    'version': '2.0.0'
}
if '$reason' != '':
    payload['reason'] = '$reason'
if custom:
    payload['custom_data'] = custom
print(json.dumps(payload))
" 2>/dev/null)
    
    if [[ -n "$payload" ]]; then
        curl -s -X POST "$webhook_url" \
            -H "Content-Type: application/json" \
            -H "User-Agent: SudoMe/2.0.0" \
            -d "$payload" \
            --max-time "$timeout" \
            > /dev/null 2>&1 &
        log info "Webhook sent: $action for $username"
    fi
}

# ── Send desktop notification (as the user, not root) ──────────────────
notify_user() {
    local username="$1"
    local title="$2"
    local message="$3"
    local urgency="${4:-normal}"
    
    local uid
    uid=$(id -u "$username" 2>/dev/null) || return 0
    
    local dbus_addr
    dbus_addr=$(cat "/run/user/${uid}/bus" 2>/dev/null || true)
    
    if [[ -n "$dbus_addr" ]] && command -v gdbus &>/dev/null; then
        local urg_val=1
        [[ "$urgency" == "critical" ]] && urg_val=2
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${uid}/bus" \
        gdbus call --session \
            --dest org.freedesktop.Notifications \
            --object-path /org/freedesktop/Notifications \
            --method org.freedesktop.Notifications.Notify \
            "sudome" 0 "sudome" "$title" "$message" \
            '[]' "{'urgency': <$urg_val>}" \
            -1 2>/dev/null || true
    fi
}

# ── Grant sudo ─────────────────────────────────────────────────────────
cmd_grant() {
    validate_user
    local minutes="${ARG3:-30}"
    local reason="${ARG4:-}"
    
    # Validate minutes
    if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [[ "$minutes" -lt 1 ]]; then
        log err "Invalid minutes value: '$minutes'"
        echo "ERROR: Invalid duration. Must be a positive integer."
        exit 1
    fi

    # NEW: Check entity authorization (SAP Privileges feature)
    check_allowed_denied "$USERNAME"

    # NEW: Apply per-user timeout override (MakeMeAdmin feature)
    local default_minutes
    default_minutes=$(get_config "default_duration" "30")
    minutes=$(get_user_timeout "$USERNAME" "$minutes")
    if [[ "$minutes" -eq 0 ]]; then
        # 0 override = unlimited, skip max_duration check
        minutes=525600  # 1 year, effectively unlimited
        log info "User '$USERNAME' granted unlimited duration via override"
    fi
    
    # Validate reason — if required and not provided, prompt interactively
    # This runs AFTER pkexec authentication (pkexec preserves /dev/tty)
    if [[ -z "$reason" ]]; then
        local require_reason
        require_reason=$(get_config "require_reason" "false")
        if [[ "$require_reason" == "true" ]]; then
            reason=$(prompt_reason_interactive)
        fi
    fi
    validate_reason "$reason"
    
    # Enforce max_duration from config
    local max_dur
    max_dur=$(get_config "max_duration" "0")
    if [[ "$max_dur" -gt 0 ]] && [[ "$minutes" -gt "$max_dur" ]]; then
        log err "Duration $minutes exceeds max_duration $max_dur"
        echo "ERROR: Maximum allowed duration is $max_dur minutes"
        exit 1
    fi

    # Check if already in sudo group
    if groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        echo "ALREADY_ACTIVE"
        log info "User '$USERNAME' already in sudo group"
        exit 0
    fi

    # NEW: Clear renewal count on fresh grant
    clear_renewal_count "$USERNAME"

    # Add to sudo group
    if usermod -a -G "$SUDO_GROUP" "$USERNAME" 2>/dev/null; then
        local expiry now_ts
        now_ts=$(date +%s 2>/dev/null || python3 -c "import time; print(int(time.time()))")
        expiry=$((now_ts + minutes * 60))

        # Atomic state file write
        mkdir -p "$STATE_DIR"
        atomic_write "${STATE_DIR}/${USERNAME}.expiry" "$expiry"

        # Write syslog audit event
        local now=$(date '+%m/%d/%Y %I:%M:%S %p')
        local log_msg="GRANT: user='$USERNAME' minutes=$minutes expiry=$expiry"
        if [[ -n "$reason" ]]; then
            log_msg="$log_msg reason='$reason'"
        fi
        log notice "$log_msg"

        # Structured event for SIEM (matching SAP Privileges format)
        local structured_msg="Process sudome created at $now by user $USERNAME in session $(loginctl list-sessions --no-legend 2>/dev/null | grep "$USERNAME" | awk '{print $1}' | head -1 || echo '?') with an elevation type of Default. action: 'grant' minutes: '$minutes'"
        if [[ -n "$reason" ]]; then
            structured_msg="$structured_msg reason: '$reason'"
        fi
        logger -t "$LOG_TAG" -p auth.notice "$structured_msg"

        # Desktop notification
        local notify_msg="You now have administrator privileges for ${minutes} minutes."
        if [[ -n "$reason" ]]; then
            notify_msg="${notify_msg} Reason: ${reason}"
        fi
        notify_user "$USERNAME" \
            "🔓 Administrator Privileges Granted" \
            "${notify_msg}" \
            "normal"

        # Post-change action
        run_post_change_action "grant" "$USERNAME" "$minutes" "$reason"
        
        # Webhook
        send_webhook "grant" "$USERNAME" "$minutes" "$reason" "$expiry"

        echo "GRANTED $minutes $expiry"
    else
        log err "Failed to add '$USERNAME' to '$SUDO_GROUP' group"
        echo "ERROR: Failed to grant sudo access"
        exit 1
    fi
}

# ── Revoke sudo ────────────────────────────────────────────────────────
cmd_revoke() {
    validate_user
    local reason="${ARG3:-}"
    
    # Check if in sudo group
    if ! groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        echo "NOT_ACTIVE"
        log info "User '$USERNAME' not in sudo group — nothing to revoke"
        exit 0
    fi

    # Remove from sudo group
    if deluser "$USERNAME" "$SUDO_GROUP" 2>/dev/null || \
       gpasswd -d "$USERNAME" "$SUDO_GROUP" 2>/dev/null; then
        rm -f "${STATE_DIR}/${USERNAME}.expiry"

        local now=$(date '+%m/%d/%Y %I:%M:%S %p')
        local log_msg="REVOKE: user='$USERNAME'"
        if [[ -n "$reason" ]]; then
            log_msg="$log_msg reason='$reason'"
        fi
        log notice "$log_msg"

        logger -t "$LOG_TAG" -p auth.notice \
            "Administrator privileges have been revoked for user $USERNAME at $now."

        # Desktop notification
        local notify_msg="Your elevation has expired. You have been demoted back to a standard user."
        if [[ -n "$reason" ]]; then
            notify_msg="${notify_msg} (${reason})"
        fi
        notify_user "$USERNAME" \
            "🔒 Administrator Privileges Revoked" \
            "${notify_msg}" \
            "normal"

        # Post-change action
        run_post_change_action "revoke" "$USERNAME" "0" "$reason"
        
        # Webhook
        send_webhook "revoke" "$USERNAME" "0" "$reason" "0"

        echo "REVOKED"
    else
        log err "Failed to remove '$USERNAME' from '$SUDO_GROUP' group"
        echo "ERROR: Failed to revoke sudo access"
        exit 1
    fi
}

# ── Check status ───────────────────────────────────────────────────────
cmd_status() {
    validate_user

    if groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        if [[ -f "${STATE_DIR}/${USERNAME}.expiry" ]]; then
            local expiry now remaining
            expiry=$(cat "${STATE_DIR}/${USERNAME}.expiry")
            now=$(date +%s)
            remaining=$((expiry - now))
            echo "ACTIVE $remaining $expiry"
        else
            echo "ACTIVE 0 0"
        fi
    else
        echo "NOT_ACTIVE"
    fi
}

# ── Renew sudo (extend existing grant) ─────────────────────────────────
cmd_renew() {
    validate_user
    local minutes="${ARG3:-30}"
    local reason="${ARG4:-}"
    
    # Validate minutes
    if ! [[ "$minutes" =~ ^[0-9]+$ ]] || [[ "$minutes" -lt 1 ]]; then
        log err "Invalid minutes value: '$minutes'"
        echo "ERROR: Invalid duration. Must be a positive integer."
        exit 1
    fi
    
    validate_reason "$reason"

    # NEW: Check renewal limit (MakeMeAdmin feature)
    check_renewal_limit "$USERNAME"

    # Check if currently active
    if ! groups "$USERNAME" | grep -qw "$SUDO_GROUP"; then
        echo "NOT_ACTIVE"
        log info "User '$USERNAME' not in sudo group — cannot renew"
        exit 0
    fi

    # Extend expiry
    mkdir -p "$STATE_DIR"
    local now_ts new_expiry
    now_ts=$(date +%s 2>/dev/null || python3 -c "import time; print(int(time.time()))")
    
    if [[ -f "${STATE_DIR}/${USERNAME}.expiry" ]]; then
        local current_expiry
        current_expiry=$(cat "${STATE_DIR}/${USERNAME}.expiry")
        if [[ "$current_expiry" -lt "$now_ts" ]]; then
            new_expiry=$((now_ts + minutes * 60))
        else
            new_expiry=$((current_expiry + minutes * 60))
        fi
    else
        new_expiry=$((now_ts + minutes * 60))
    fi
    
    atomic_write "${STATE_DIR}/${USERNAME}.expiry" "$new_expiry"

    # NEW: Increment renewal counter
    increment_renewal_count "$USERNAME"
    
    local log_msg="RENEW: user='$USERNAME' minutes=$minutes expiry=$new_expiry"
    if [[ -n "$reason" ]]; then
        log_msg="$log_msg reason='$reason'"
    fi
    log notice "$log_msg"
    
    send_webhook "renew" "$USERNAME" "$minutes" "$reason" "$new_expiry"
    
    echo "GRANTED $minutes $new_expiry"
}

# ── Main ───────────────────────────────────────────────────────────────
case "$ACTION" in
    grant)  cmd_grant ;;
    revoke) cmd_revoke ;;
    renew)  cmd_renew ;;
    status) cmd_status ;;
    *)
        echo "ERROR: Unknown action '$ACTION'. Use: grant|revoke|renew|status <username> [minutes] [reason]"
        exit 1
        ;;
esac
