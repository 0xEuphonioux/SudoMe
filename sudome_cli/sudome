#!/usr/bin/env python3
"""
SudoMe CLI — Temporary sudo elevation for Linux.

Usage:
    sudome on [minutes]       Grant sudo for N minutes (default: 30)
    sudome off                Revoke sudo immediately
    sudome status             Show current sudo status
    sudome renew [minutes]    Extend the current sudo grant

Examples:
    sudome on                 # 30 minutes of sudo
    sudome on 60              # 60 minutes of sudo
    sudome status             # ACTIVE 25m remaining
    sudome renew 15           # Extend by 15 minutes
    sudome off                # Revoke now

SudoMe mirrors SAP Privileges for macOS — temporary admin rights,
automatic revocation, audit logging, enterprise-ready.
"""

import argparse
import os
import subprocess
import sys
import time
from pathlib import Path

VERSION = "2.0.0"
HELPER_PATH = "/usr/lib/sudome/sudome-helper"
STATE_DIR = "/var/lib/sudome"
CONFIG_FILE = "/etc/sudome/config.yaml"
PKEXEC = "/usr/bin/pkexec"

# ── Terminal colors ────────────────────────────────────────────────────
class Colors:
    GREEN = "\033[92m"
    RED = "\033[91m"
    YELLOW = "\033[93m"
    CYAN = "\033[96m"
    BOLD = "\033[1m"
    RESET = "\033[0m"

def bold(s):  return f"{Colors.BOLD}{s}{Colors.RESET}"
def green(s): return f"{Colors.GREEN}{s}{Colors.RESET}"
def red(s):   return f"{Colors.RED}{s}{Colors.RESET}"
def yellow(s): return f"{Colors.YELLOW}{s}{Colors.RESET}"
def cyan(s):  return f"{Colors.CYAN}{s}{Colors.RESET}"

# ── Helpers ────────────────────────────────────────────────────────────
def run_helper(action: str, minutes: int = 0, reason: str = "") -> tuple[int, str]:
    """Run the Polkit helper, returning (exit_code, output)."""
    # Use getlogin() or getpwuid for trusted username — never trust USER env var
    import pwd
    try:
        username = os.getlogin()
    except OSError:
        username = pwd.getpwuid(os.getuid()).pw_name

    cmd = [PKEXEC, HELPER_PATH, action, username]
    if action in ("grant", "renew") and minutes > 0:
        cmd.append(str(minutes))
        if reason:
            cmd.append(reason)
    elif action == "revoke" and reason:
        cmd.append(reason)

    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=60
        )
        return result.returncode, result.stdout.strip() + result.stderr.strip()
    except subprocess.TimeoutExpired:
        return 1, "ERROR: Operation timed out"
    except FileNotFoundError:
        return 1, "ERROR: pkexec not found. Is PolicyKit installed?"

def get_status() -> tuple[str, int, int]:
    """Returns (state, remaining_seconds, expiry_timestamp).
    
    Uses direct filesystem/group checks — no pkexec needed.
    pkexec for 'status' was matching the grant action (auth_self)
    and causing a spurious auth prompt.
    """
    import pwd
    try:
        username = os.getlogin()
    except OSError:
        username = pwd.getpwuid(os.getuid()).pw_name
    
    try:
        result = subprocess.run(
            ["groups", username],
            capture_output=True, text=True, timeout=5
        )
        in_sudo = "sudo" in result.stdout
    except Exception:
        return "ERROR", 0, 0
    
    if not in_sudo:
        return "NOT_ACTIVE", 0, 0
    
    state_file = f"/var/lib/sudome/{username}.expiry"
    try:
        with open(state_file) as f:
            expiry = int(f.read().strip())
        now = int(time.time())
        remaining = expiry - now
        if remaining <= 0:
            return "NOT_ACTIVE", 0, 0
        return "ACTIVE", remaining, expiry
    except (PermissionError, FileNotFoundError, ValueError):
        return "ACTIVE_UNKNOWN", 0, 0

def _get_reason_config():
    """Read reason enforcement config. Returns (require, presets, min_len, strict)."""
    try:
        import yaml
        if os.path.exists(CONFIG_FILE):
            with open(CONFIG_FILE) as f:
                config = yaml.safe_load(f) or {}
            return (
                config.get("require_reason", False),
                config.get("reason_presets", []),
                config.get("reason_min_length", 0),
                config.get("reason_strict_presets", False),
            )
    except Exception:
        pass
    return False, [], 0, False

def _prompt_reason():
    """Interactively prompt user for reason. Returns reason string or exits."""
    require_reason, presets, min_len, strict = _get_reason_config()
    if not require_reason:
        return ""
    
    reason = ""
    print()
    print(f"  {bold('Reason required')} for requesting administrator privileges:")
    
    if presets:
        print()
        for i, preset in enumerate(presets, 1):
            print(f"    {bold(f'[{i}]')} {preset}")
        if not strict:
            print(f"    {bold('[0]')} Enter custom reason")
        print()
        try:
            choice = input(f"  Select [{cyan('1')}-{cyan(str(len(presets)))}]: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
        if choice.isdigit():
            idx = int(choice)
            if 1 <= idx <= len(presets):
                reason = presets[idx - 1]
        if not reason:
            if strict:
                print(red("Invalid selection"))
                sys.exit(1)
            # fall through to custom input
    
    if not reason:
        try:
            reason = input(f"  Enter reason: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(0)
    
    if not reason:
        print(red("Reason cannot be empty"))
        sys.exit(1)
    if min_len > 0 and len(reason) < min_len:
        print(red(f"Reason must be at least {min_len} characters (got {len(reason)})"))
        sys.exit(1)
    
    return reason

def format_time(seconds: int) -> str:
    """Format seconds into human-readable time."""
    if seconds <= 0:
        return "expired"
    m, s = divmod(seconds, 60)
    h, m = divmod(m, 60)
    if h > 0:
        return f"{h}h {m}m"
    elif m > 0:
        return f"{m}m {s}s"
    else:
        return f"{s}s"

# ── Commands ───────────────────────────────────────────────────────────
def cmd_status():
    """Show current sudo status."""
    state, remaining, expiry = get_status()

    if state in ("ACTIVE", "ACTIVE_UNKNOWN"):
        print(f"  {green('●')} Sudo is {bold('ACTIVE')}")
        print(f"    Time remaining: {cyan(format_time(remaining))}")
        if expiry > 0:
            expiry_str = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(expiry))
            print(f"    Expires at:     {expiry_str}")
        print()
        print(f"  Run {bold('sudome off')} to revoke immediately")
        print(f"  Run {bold('sudome renew')} to extend")
    elif state == "NOT_ACTIVE":
        print(f"  {yellow('○')} Sudo is {bold('NOT active')}")
        print(f"  Run {bold('sudome on')} to request temporary sudo")
    else:
        print(f"  {red('✗')} {red(state)}")

def cmd_on(minutes: int = 30, reason: str = ""):
    """Request temporary sudo access."""
    if minutes < 1:
        print(red("Minutes must be at least 1"))
        sys.exit(1)

    # Collect reason BEFORE auth (reason first, then pkexec auth prompt)
    if not reason:
        reason = _prompt_reason()

    # Check if already active
    state, remaining, _ = get_status()
    if state in ("ACTIVE", "ACTIVE_UNKNOWN"):
        print(yellow(f"Sudo is already active ({format_time(remaining)} remaining)"))
        print(f"Run {bold('sudome renew')} to extend, or {bold('sudome off')} to revoke first")
        sys.exit(0)

    print(f"Requesting sudo for {bold(str(minutes))} minutes...")
    if reason:
        print(f"  Reason: {reason}")
    
    # pkexec runs here — this triggers the Polkit auth dialog
    ret, output = run_helper("grant", minutes, reason)

    if ret == 0 and output.startswith("GRANTED"):
        parts = output.split()
        actual_minutes = int(parts[1]) if len(parts) > 1 else minutes
        expiry_ts = int(parts[2]) if len(parts) > 2 else 0

        print()
        print(f"  {green('✓')} {bold('Sudo granted!')}")
        print(f"    Duration:  {cyan(str(actual_minutes))} minutes")
        if expiry_ts:
            expiry_str = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(expiry_ts))
            print(f"    Expires:   {expiry_str}")
        print()
        print(f"  You now have admin privileges. They will be")
        print(f"  automatically revoked when the timer expires.")
    elif output == "ALREADY_ACTIVE":
        print(yellow("Sudo is already active"))
    else:
        print(red(f"Failed to grant sudo: {output}"))
        sys.exit(1)

def cmd_off(reason: str = ""):
    """Revoke sudo immediately."""
    state, remaining, _ = get_status()

    if state not in ("ACTIVE", "ACTIVE_UNKNOWN"):
        print(yellow("Sudo is not currently active"))
        sys.exit(0)

    if remaining > 0:
        print(f"Revoking sudo ({format_time(remaining)} remaining)...")
    else:
        print("Revoking sudo...")

    ret, output = run_helper("revoke", reason=reason)

    if ret == 0 and "REVOKED" in output:
        print(f"  {green('✓')} {bold('Sudo revoked')}")
        print(f"  You are now back to standard user privileges.")
    elif "NOT_ACTIVE" in output:
        print(yellow("Sudo was not active"))
    else:
        print(red(f"Failed to revoke sudo: {output}"))
        sys.exit(1)

def cmd_renew(minutes: int = 30, reason: str = ""):
    """Extend current sudo grant."""
    state, remaining, expiry = get_status()

    if state not in ("ACTIVE", "ACTIVE_UNKNOWN"):
        print(yellow("Sudo is not currently active"))
        print(f"Run {bold('sudome on')} to request sudo first")
        sys.exit(1)

    print(f"Extending sudo by {bold(str(minutes))} more minutes...")
    ret, output = run_helper("renew", minutes, reason)

    if ret == 0 and output.startswith("GRANTED"):
        parts = output.split()
        new_expiry = int(parts[2]) if len(parts) > 2 else 0
        print()
        print(f"  {green('✓')} {bold('Sudo extended!')}")
        if new_expiry:
            expiry_str = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(new_expiry))
            print(f"    New expiry: {expiry_str}")
    else:
        print(red(f"Failed to extend: {output}"))
        sys.exit(1)

# ── Main ───────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        description="SudoMe — Temporary sudo privilege elevation",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  sudome on              Grant sudo for 30 minutes
  sudome on 60           Grant sudo for 60 minutes  
  sudome status          Check current status
  sudome renew           Extend by 30 minutes
  sudome renew 15        Extend by 15 minutes
  sudome off             Revoke immediately
        """
    )
    parser.add_argument("--version", action="version", version=f"SudoMe v{VERSION}")

    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # sudome on [minutes] [--reason "..."]
    on_parser = subparsers.add_parser("on", help="Grant temporary sudo access")
    on_parser.add_argument("minutes", nargs="?", type=int, default=30,
                          help="Duration in minutes (default: 30)")
    on_parser.add_argument("--reason", "-r", type=str, default="",
                          help="Reason for requesting admin privileges")

    # sudome off [--reason "..."]
    off_parser = subparsers.add_parser("off", help="Revoke temporary sudo access")
    off_parser.add_argument("--reason", "-r", type=str, default="",
                           help="Reason for revoking early")

    # sudome status
    subparsers.add_parser("status", aliases=["st"], help="Show current sudo status")

    # sudome renew [minutes] [--reason "..."]
    renew_parser = subparsers.add_parser("renew", help="Extend current sudo grant")
    renew_parser.add_argument("minutes", nargs="?", type=int, default=30,
                             help="Additional minutes (default: 30)")
    renew_parser.add_argument("--reason", "-r", type=str, default="",
                             help="Reason for extending")

    args = parser.parse_args()

    if not args.command:
        # Default: show status
        cmd_status()
    elif args.command == "on":
        cmd_on(args.minutes, args.reason)
    elif args.command == "off":
        cmd_off(args.reason)
    elif args.command in ("status", "st"):
        cmd_status()
    elif args.command == "renew":
        cmd_renew(args.minutes, args.reason)

if __name__ == "__main__":
    main()
