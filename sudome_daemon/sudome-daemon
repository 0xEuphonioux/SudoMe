#!/usr/bin/env python3
"""
SudoMe Daemon 0.1.0-beta — Long-running listener for auto-revocation and
elevated process logging (from MakeMeAdmin feature set).

Monitored events:
  - Session lock / sleep / time change / shutdown → auto-revoke
  - Timer expiry → revoke
  - Elevated process logging → syslog audit of sudo commands

Runs as a systemd user service.
"""

import os
import re
import signal
import subprocess
import sys
import threading
import time
from pathlib import Path

try:
    import yaml
    HAS_YAML = True
except ImportError:
    HAS_YAML = False

try:
    import gi
    gi.require_version("GLib", "2.0")
    from gi.repository import GLib
    HAS_GLIB = True
except ImportError:
    HAS_GLIB = False

try:
    import dbus
    import dbus.mainloop.glib
    from dbus.mainloop.glib import DBusGMainLoop
    HAS_DBUS = True
except ImportError:
    HAS_DBUS = False

STATE_DIR = "/var/lib/sudome"
CONFIG_FILE = "/etc/sudome/config.yaml"
POLICY_FILE = "/etc/sudome/policy.yaml"
HELPER_PATH = "/usr/lib/sudome/sudome-helper"
HELPER_REVOKE_PATH = "/usr/lib/sudome/sudome-helper-revoke"
PKEXEC = "/usr/bin/pkexec"
LOG_TAG = "sudome-daemon"
CHECK_INTERVAL = 10

# ── Configuration ──────────────────────────────────────────────────────
_config = None
_config_loaded = False

def load_config():
    """Load merged config (policy.yaml overrides config.yaml)."""
    global _config, _config_loaded
    if _config_loaded:
        return _config
    _config = {}

    if not HAS_YAML:
        _config_loaded = True
        return _config

    # Load config.yaml
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE) as f:
                _config = yaml.safe_load(f) or {}
        except Exception:
            pass

    # Load policy.yaml (overrides config)
    if os.path.exists(POLICY_FILE):
        try:
            with open(POLICY_FILE) as f:
                policy = yaml.safe_load(f)
            if policy:
                _config.update(policy)
        except Exception:
            pass

    _config_loaded = True
    return _config

def cfg(key, default=None):
    return load_config().get(key, default)

def get_excluded_users():
    excluded = cfg("auto_revoke_excluded_users", [])
    if isinstance(excluded, list):
        return [u for u in excluded if isinstance(u, str)]
    return []

def get_per_trigger_excluded(trigger: str):
    """Get per-trigger exclusions (SAP Privileges feature)."""
    exclusions = cfg("auto_revoke_exclusions", {})
    if isinstance(exclusions, dict):
        excluded = exclusions.get(trigger, [])
        if isinstance(excluded, list):
            return [u for u in excluded if isinstance(u, str)]
    return []

def is_renewal_allowed():
    return bool(cfg("allow_privilege_renewal", True))

def get_notify_before():
    return int(cfg("notify_before_expiry", 300))

def get_renewal_interval():
    return int(cfg("renewal_notification_interval", 60))

def is_elevated_process_logging():
    return bool(cfg("log_elevated_processes", False))

# ── Logging ────────────────────────────────────────────────────────────
def log(level: str, message: str):
    subprocess.run(
        ["logger", "-t", LOG_TAG, "-p", f"daemon.{level}", message],
        capture_output=True,
    )

def log_elevated_process(username: str, pid: str, command: str):
    """Log an elevated process — mirrors MakeMeAdmin elevated process logging."""
    import datetime
    now = datetime.datetime.now().strftime("%m/%d/%Y %I:%M:%S %p")
    msg = (f"Process started at {now} by user {username} "
           f"(PID {pid}) as administrator: {command}")
    subprocess.run(
        ["logger", "-t", "sudome-elevated", "-p", "auth.notice", msg],
        capture_output=True,
    )

# ── Elevated Process Logging (MakeMeAdmin feature) ──────────────────────
_elevated_logger_running = False
_elevated_logger_thread = None

def start_elevated_process_logger():
    """Start a background thread that monitors sudo command execution
    for all users with active grants, logging each elevated process."""
    global _elevated_logger_running, _elevated_logger_thread

    if _elevated_logger_running:
        return

    if not is_elevated_process_logging():
        log("info", "Elevated process logging disabled in config")
        return

    _elevated_logger_running = True
    _elevated_logger_thread = threading.Thread(
        target=_elevated_process_logger_loop,
        daemon=True,
        name="elevated-process-logger"
    )
    _elevated_logger_thread.start()
    log("info", "Elevated process logging started (monitoring sudo commands)")

def _elevated_process_logger_loop():
    """Poll journalctl for sudo commands from elevated users."""
    sudo_pattern = re.compile(r"^\w+\s+\d+\s+\d{2}:\d{2}:\d{2}\s+\S+\s+sudo\[\d+\]:\s+(\S+)\s+:\s+TTY=\S+\s+;\s+PWD=\S+\s+;\s+USER=root\s+;\s+COMMAND=(.+)")

    while _elevated_logger_running:
        try:
            # Get currently elevated users
            active = get_active_usernames_including_expired()
            if not active:
                time.sleep(CHECK_INTERVAL)
                continue

            # Query recent sudo journal entries
            result = subprocess.run(
                ["journalctl", "-t", "sudo", "--since", "30 seconds ago",
                 "--no-pager", "-o", "cat"],
                capture_output=True, text=True, timeout=15
            )

            for line in result.stdout.strip().split("\n"):
                match = sudo_pattern.search(line)
                if not match:
                    # Try alternate format
                    alt_match = re.search(
                        r"(\S+)\s+:\s+TTY=\S+\s+;\s+PWD=\S+\s+;\s+USER=root\s+;\s+COMMAND=(.+)",
                        line
                    )
                    if not alt_match:
                        continue
                    username = alt_match.group(1)
                    command = alt_match.group(2)
                else:
                    username = match.group(1)
                    command = match.group(2)

                # Only log if user has an active grant
                if has_active_grant(username):
                    # Get PID from journalctl for richer logging
                    pid = "?"
                    pid_match = re.search(r"sudo\[(\d+)\]", line)
                    if pid_match:
                        pid = pid_match.group(1)

                    log_elevated_process(username, pid, command)

        except subprocess.TimeoutExpired:
            pass
        except Exception as e:
            log("warn", f"Elevated process logger error: {e}")

        time.sleep(CHECK_INTERVAL)

def stop_elevated_process_logger():
    global _elevated_logger_running
    _elevated_logger_running = False
    log("info", "Elevated process logging stopped")

# ── Notifications ──────────────────────────────────────────────────────
_notified_users = {}

def send_notification(username: str, title: str, message: str, urgency: str = "normal"):
    try:
        uid = None
        result = subprocess.run(["id", "-u", username], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            uid = result.stdout.strip()
        if not uid:
            return

        urg_val = "2" if urgency == "critical" else "1"
        bus_path = f"/run/user/{uid}/bus"
        if not os.path.exists(bus_path):
            return

        env = os.environ.copy()
        env["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={bus_path}"
        subprocess.run(
            ["gdbus", "call", "--session",
             "--dest", "org.freedesktop.Notifications",
             "--object-path", "/org/freedesktop/Notifications",
             "--method", "org.freedesktop.Notifications.Notify",
             "sudome", "0", "sudome", title, message,
             "[]", "{'urgency': <" + urg_val + ">}", "-1"],
            capture_output=True, timeout=10,
            env=env
        )
    except Exception:
        pass

# ── Revocation ─────────────────────────────────────────────────────────
def has_active_grant(username: str) -> bool:
    """Check if a user has an active (non-expired) sudo grant."""
    fpath = os.path.join(STATE_DIR, f"{username}.expiry")
    if not os.path.isfile(fpath):
        return False
    try:
        with open(fpath) as f:
            expiry = int(f.read().strip())
        return expiry > int(time.time())
    except (ValueError, OSError):
        return False

def get_active_usernames_including_expired() -> list:
    """Get all users who have requested sudo (including expired grants)."""
    if not os.path.isdir(STATE_DIR):
        return []
    users = []
    for fname in os.listdir(STATE_DIR):
        if fname.endswith(".expiry"):
            users.append(fname[:-7])
    return users

def revoke_user(username: str, reason: str = "auto-revoked by daemon"):
    global_excluded = get_excluded_users()
    if username in global_excluded:
        log("info", f"Skipping auto-revoke for excluded user '{username}' ({reason})")
        return True

    # Check per-trigger exclusions (SAP Privileges feature)
    trigger_map = {
        "session locked": "screen_lock_excluded",
        "system sleep": "sleep_excluded",
        "time/date changed": "time_change_excluded",
        "system shutdown": "shutdown_excluded",
    }
    trigger_key = trigger_map.get(reason)
    if trigger_key:
        per_trigger = get_per_trigger_excluded(trigger_key)
        if username in per_trigger:
            log("info", f"Skipping {reason} revoke for per-trigger excluded user '{username}'")
            return True

    try:
        result = subprocess.run(
            [PKEXEC, HELPER_REVOKE_PATH, "revoke", username, reason],
            capture_output=True, text=True, timeout=30
        )
        if "REVOKED" in result.stdout or "NOT_ACTIVE" in result.stdout:
            log("info", f"Revoked sudo for '{username}': {reason}")
            _notified_users.pop(username, None)
            return True
        else:
            log("err", f"Failed to revoke '{username}': {result.stdout.strip()}")
            return False
    except Exception as e:
        log("err", f"Exception revoking '{username}': {e}")
        return False

def revoke_all_active(reason: str = "auto-revoked by daemon"):
    if not os.path.isdir(STATE_DIR):
        return

    excluded = get_excluded_users()
    for fname in os.listdir(STATE_DIR):
        if not fname.endswith(".expiry"):
            continue
        username = fname[:-7]
        if username in excluded:
            continue
        revoke_user(username, reason)

def get_active_usernames() -> list:
    """Get list of users with active sudo grants."""
    if not os.path.isdir(STATE_DIR):
        return []
    users = []
    for fname in os.listdir(STATE_DIR):
        if fname.endswith(".expiry"):
            username = fname[:-7]
            if has_active_grant(username) and username not in get_excluded_users():
                users.append(username)
    return users

def check_expired():
    if not os.path.isdir(STATE_DIR):
        return

    now = int(time.time())
    notify_before = get_notify_before()
    renewal_interval = get_renewal_interval()
    renewal_allowed = is_renewal_allowed()
    excluded = get_excluded_users()

    for fname in os.listdir(STATE_DIR):
        if not fname.endswith(".expiry"):
            continue
        username = fname[:-7]

        if username in excluded:
            continue

        fpath = os.path.join(STATE_DIR, fname)
        try:
            with open(fpath) as f:
                expiry = int(f.read().strip())
        except (ValueError, OSError):
            continue

        if expiry <= now:
            log("notice", f"Timer expired for '{username}'")
            revoke_user(username, "timer expired")
            continue

        remaining = expiry - now

        if notify_before > 0 and remaining <= notify_before:
            last_notified = _notified_users.get(username, 0)
            if expiry != last_notified:
                mins = remaining // 60
                secs = remaining % 60
                send_notification(
                    username,
                    "Sudo Expiring Soon",
                    f"Your administrator privileges expire in {mins}m {secs}s.",
                    "normal"
                )
                _notified_users[username] = expiry

        if renewal_allowed and renewal_interval > 0 and remaining <= renewal_interval:
            last_notified = _notified_users.get(username, 0)
            if expiry != last_notified:
                send_notification(
                    username,
                    "SudoMe — Renew Privileges?",
                    f"Your sudo access expires in {remaining} seconds. "
                    f"Run 'sudome renew' or click Extend Sudo to renew.",
                    "critical"
                )
                _notified_users[username] = expiry

# ── Event handlers ─────────────────────────────────────────────────────
def on_session_lock(locked: bool):
    if locked:
        users = get_active_usernames()
        if users:
            log("notice", f"Session locked — revoking sudo for {len(users)} user(s)")
            for username in users:
                revoke_user(username, "session locked")

def on_prepare_for_sleep(going_to_sleep: bool):
    if going_to_sleep:
        users = get_active_usernames()
        if users:
            log("notice", f"System sleeping — revoking sudo for {len(users)} user(s)")
            for username in users:
                revoke_user(username, "system sleep")

def on_time_changed():
    users = get_active_usernames()
    if users:
        log("notice", f"Time/date changed — revoking sudo for {len(users)} user(s)")
        for username in users:
            revoke_user(username, "time/date changed")

def on_shutdown():
    users = get_active_usernames()
    if users:
        log("notice", f"Daemon shutting down — revoking sudo for {len(users)} user(s)")
        for username in users:
            revoke_user(username, "system shutdown")

# ── D-Bus setup ────────────────────────────────────────────────────────
def setup_dbus_listeners(loop):
    if not HAS_DBUS:
        log("warn", "python3-dbus not available — D-Bus event monitoring disabled")
        return None

    try:
        dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)
        bus = dbus.SystemBus()

        try:
            session_id = os.environ.get("XDG_SESSION_ID", "")
            if session_id:
                session_path = f"/org/freedesktop/login1/session/{session_id}"
                session = bus.get_object("org.freedesktop.login1", session_path)
                session.connect_to_signal(
                    "Lock", lambda: on_session_lock(True),
                    dbus_interface="org.freedesktop.login1.Session"
                )
                log("info", f"Monitoring session {session_id} for lock events")
        except Exception as e:
            log("warn", f"Could not connect to session lock signal: {e}")

        try:
            manager = bus.get_object("org.freedesktop.login1", "/org/freedesktop/login1")
            manager.connect_to_signal(
                "PrepareForSleep",
                on_prepare_for_sleep,
                dbus_interface="org.freedesktop.login1.Manager"
            )
            log("info", "Monitoring logind for sleep events")
        except Exception as e:
            log("warn", f"Could not connect to PrepareForSleep signal: {e}")

        return bus

    except Exception as e:
        log("err", f"Failed to connect to D-Bus: {e}")
        return None

# ── Main ───────────────────────────────────────────────────────────────
def main():
    log("info", "SudoMe daemon 0.1.0-beta starting")
    excluded = get_excluded_users()
    if excluded:
        log("info", f"Auto-revoke excluded users: {', '.join(excluded)}")

    # Revoke orphaned expired grants on startup
    check_expired()

    # Start elevated process logging (MakeMeAdmin feature)
    start_elevated_process_logger()

    if not HAS_GLIB:
        log("err", "python3-gi not available — cannot run event loop")
        sys.exit(1)

    def sigterm_handler(signum, frame):
        log("info", "Received SIGTERM — shutting down")
        stop_elevated_process_logger()
        on_shutdown()
        loop.quit()

    signal.signal(signal.SIGTERM, sigterm_handler)
    signal.signal(signal.SIGINT, sigterm_handler)

    loop = GLib.MainLoop()
    bus = setup_dbus_listeners(loop)

    def periodic_check():
        check_expired()
        return True

    GLib.timeout_add_seconds(CHECK_INTERVAL, periodic_check)

    log("info", f"Daemon running (checking every {CHECK_INTERVAL}s)")

    try:
        loop.run()
    except KeyboardInterrupt:
        stop_elevated_process_logger()
        on_shutdown()

    log("info", "SudoMe daemon stopped")

if __name__ == "__main__":
    main()
