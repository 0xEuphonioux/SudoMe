#!/usr/bin/env python3
"""
SudoMe Daemon — Long-running D-Bus listener that automatically revokes
sudo when the session locks, the system sleeps, the time/date changes,
or the expiry timer runs out. Mirrors SAP Privileges revocation behavior.

Monitored events:
  - Session lock (logind Lock signal)        → revoke
  - System sleep (logind PrepareForSleep)     → revoke
  - Time/date change (timedated)              → revoke
  - Shutdown (SIGTERM handler)               → revoke all
  - Timer expiry (internal 10s check)         → revoke

Enterprise features:
  - Excluded users (service accounts immune to auto-revoke)
  - Proactive renewal notification before expiry
  - Config-driven via /etc/sudome/config.yaml

Runs as a systemd user service (long-running, not oneshot).
"""

import os
import signal
import subprocess
import sys
import time
from pathlib import Path

try:
    import yaml
    HAS_YAML = True
except ImportError:
    HAS_YAML = False

try:
    import gi
    gi.require_version("GLib", "2.0")
    from gi.repository import GLib
    HAS_GLIB = True
except ImportError:
    HAS_GLIB = False

try:
    import dbus
    import dbus.mainloop.glib
    from dbus.mainloop.glib import DBusGMainLoop
    HAS_DBUS = True
except ImportError:
    HAS_DBUS = False

STATE_DIR = "/var/lib/sudome"
CONFIG_FILE = "/etc/sudome/config.yaml"
HELPER_PATH = "/usr/lib/sudome/sudome-helper"
HELPER_REVOKE_PATH = "/usr/lib/sudome/sudome-helper-revoke"
PKEXEC = "/usr/bin/pkexec"
LOG_TAG = "sudome-daemon"
CHECK_INTERVAL = 10  # seconds between expiry checks

# ── Configuration ──────────────────────────────────────────────────────
_config = None
_config_loaded = False

def load_config():
    """Load configuration from /etc/sudome/config.yaml."""
    global _config, _config_loaded
    if _config_loaded:
        return _config
    _config = {}
    if HAS_YAML and os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE) as f:
                _config = yaml.safe_load(f) or {}
        except Exception:
            pass
    _config_loaded = True
    return _config

def get_excluded_users():
    """Get list of users excluded from auto-revocation."""
    cfg = load_config()
    excluded = cfg.get("auto_revoke_excluded_users", [])
    if isinstance(excluded, list):
        return [u for u in excluded if isinstance(u, str)]
    return []

def get_renewal_interval():
    """Get renewal notification interval (seconds before expiry)."""
    cfg = load_config()
    return int(cfg.get("renewal_notification_interval", 60))

def get_notify_before():
    """Get expiry warning notification time (seconds before expiry)."""
    cfg = load_config()
    return int(cfg.get("notify_before_expiry", 300))

def is_renewal_allowed():
    """Check if privilege renewal is allowed."""
    cfg = load_config()
    return bool(cfg.get("allow_privilege_renewal", True))

# ── Logging ────────────────────────────────────────────────────────────
def log(level: str, message: str):
    """Write to syslog."""
    subprocess.run(
        ["logger", "-t", LOG_TAG, "-p", f"daemon.{level}", message],
        capture_output=True,
    )

# ── Notifications ──────────────────────────────────────────────────────
_notified_users = {}  # user -> last expiry ts notified about

def send_notification(username: str, title: str, message: str, urgency: str = "normal"):
    """Send desktop notification to a user."""
    try:
        uid = None
        result = subprocess.run(["id", "-u", username], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            uid = result.stdout.strip()
        if not uid:
            return
        
        urg_val = "2" if urgency == "critical" else "1"
        bus_path = f"/run/user/{uid}/bus"
        if not os.path.exists(bus_path):
            return
        
        env = os.environ.copy()
        env["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={bus_path}"
        subprocess.run(
            ["gdbus", "call", "--session",
             "--dest", "org.freedesktop.Notifications",
             "--object-path", "/org/freedesktop/Notifications",
             "--method", "org.freedesktop.Notifications.Notify",
             "sudome", "0", "sudome", title, message,
             "[]", "{'urgency': <" + urg_val + ">}", "-1"],
            capture_output=True, timeout=10,
            env=env
        )
    except Exception:
        pass  # Notifications are non-critical

# ── Revocation ─────────────────────────────────────────────────────────
def revoke_user(username: str, reason: str = "auto-revoked by daemon"):
    """Revoke sudo for a specific user via pkexec (Polkit-authorized)."""
    excluded = get_excluded_users()
    if username in excluded:
        log("info", f"Skipping auto-revoke for excluded user '{username}' ({reason})")
        return True

    try:
        result = subprocess.run(
            [PKEXEC, HELPER_REVOKE_PATH, "revoke", username, reason],
            capture_output=True, text=True, timeout=30
        )
        if "REVOKED" in result.stdout or "NOT_ACTIVE" in result.stdout:
            log("info", f"Revoked sudo for '{username}': {reason}")
            # Clear notification tracking
            _notified_users.pop(username, None)
            return True
        else:
            log("err", f"Failed to revoke '{username}': {result.stdout.strip()}")
            return False
    except Exception as e:
        log("err", f"Exception revoking '{username}': {e}")
        return False

def revoke_all_active(reason: str = "auto-revoked by daemon"):
    """Revoke all currently active grants."""
    if not os.path.isdir(STATE_DIR):
        return
    
    excluded = get_excluded_users()
    for fname in os.listdir(STATE_DIR):
        if not fname.endswith(".expiry"):
            continue
        username = fname[:-7]
        if username in excluded:
            log("info", f"Skipping auto-revoke for excluded user '{username}' ({reason})")
            continue
        revoke_user(username, reason)

def get_active_usernames() -> list:
    """Get list of users with active sudo grants with expiry files."""
    if not os.path.isdir(STATE_DIR):
        return []
    users = []
    for fname in os.listdir(STATE_DIR):
        if fname.endswith(".expiry"):
            username = fname[:-7]
            if username not in get_excluded_users():
                users.append(username)
    return users

def check_expired():
    """Check all grants and revoke any that have expired.
    Also handles renewal notification for grants about to expire."""
    if not os.path.isdir(STATE_DIR):
        return
    
    now = int(time.time())
    notify_before = get_notify_before()
    renewal_interval = get_renewal_interval()
    renewal_allowed = is_renewal_allowed()
    excluded = get_excluded_users()
    
    for fname in os.listdir(STATE_DIR):
        if not fname.endswith(".expiry"):
            continue
        username = fname[:-7]
        
        # Skip excluded users
        if username in excluded:
            continue
        
        fpath = os.path.join(STATE_DIR, fname)
        try:
            with open(fpath) as f:
                expiry = int(f.read().strip())
        except (ValueError, OSError):
            continue
        
        # Timer expired → revoke
        if expiry <= now:
            log("notice", f"Timer expired for '{username}'")
            revoke_user(username, "timer expired")
            continue
        
        remaining = expiry - now
        
        # Proactive expiry warning (5 minutes before)
        if notify_before > 0 and remaining <= notify_before:
            last_notified = _notified_users.get(username, 0)
            # Only notify once per expiry cycle
            if expiry != last_notified:
                mins = remaining // 60
                secs = remaining % 60
                send_notification(
                    username,
                    "Sudo Expiring Soon",
                    f"Your administrator privileges expire in {mins}m {secs}s.",
                    "normal"
                )
                _notified_users[username] = expiry
        
        # Renewal notification (60s before expiry)
        if renewal_allowed and renewal_interval > 0 and remaining <= renewal_interval:
            last_notified = _notified_users.get(username, 0)
            if expiry != last_notified:
                send_notification(
                    username,
                    "SudoMe — Renew Privileges?",
                    f"Your sudo access expires in {remaining} seconds. "
                    f"Run 'sudome renew' or click Extend Sudo to renew.",
                    "critical"
                )
                _notified_users[username] = expiry

# ── Event handlers ─────────────────────────────────────────────────────
def on_session_lock(locked: bool):
    """Called when the session is locked or unlocked."""
    if locked:
        users = get_active_usernames()
        if users:
            log("notice", f"Session locked — revoking sudo for {len(users)} user(s)")
            for username in users:
                revoke_user(username, "session locked")

def on_prepare_for_sleep(going_to_sleep: bool):
    """Called when the system is about to sleep or has woken up."""
    if going_to_sleep:
        users = get_active_usernames()
        if users:
            log("notice", f"System sleeping — revoking sudo for {len(users)} user(s)")
            for username in users:
                revoke_user(username, "system sleep")

def on_time_changed():
    """Called when the system time/date changes."""
    users = get_active_usernames()
    if users:
        log("notice", f"Time/date changed — revoking sudo for {len(users)} user(s)")
        for username in users:
            revoke_user(username, "time/date changed")

def on_shutdown():
    """Called on daemon shutdown (SIGTERM)."""
    users = get_active_usernames()
    if users:
        log("notice", f"Daemon shutting down — revoking sudo for {len(users)} user(s)")
        for username in users:
            revoke_user(username, "system shutdown")

# ── D-Bus setup ────────────────────────────────────────────────────────
def setup_dbus_listeners(loop):
    """Connect to D-Bus system bus and listen for logind events."""
    if not HAS_DBUS:
        log("warn", "python3-dbus not available — D-Bus event monitoring disabled")
        log("warn", "Install: sudo apt install python3-dbus")
        return None
    
    try:
        dbus.mainloop.glib.DBusGMainLoop(set_as_default=True)
        bus = dbus.SystemBus()
        
        # ── Session Lock/Unlock ──────────────────────────────────────
        try:
            session_id = os.environ.get("XDG_SESSION_ID", "")
            if session_id:
                session_path = f"/org/freedesktop/login1/session/{session_id}"
                session = bus.get_object("org.freedesktop.login1", session_path)
                session.connect_to_signal(
                    "Lock", lambda: on_session_lock(True),
                    dbus_interface="org.freedesktop.login1.Session"
                )
                log("info", f"Monitoring session {session_id} for lock events")
        except Exception as e:
            log("warn", f"Could not connect to session lock signal: {e}")
        
        # ── PrepareForSleep ──────────────────────────────────────────
        try:
            manager = bus.get_object("org.freedesktop.login1", "/org/freedesktop/login1")
            manager.connect_to_signal(
                "PrepareForSleep",
                on_prepare_for_sleep,
                dbus_interface="org.freedesktop.login1.Manager"
            )
            log("info", "Monitoring logind for sleep events")
        except Exception as e:
            log("warn", f"Could not connect to PrepareForSleep signal: {e}")
        
        return bus
        
    except Exception as e:
        log("err", f"Failed to connect to D-Bus: {e}")
        return None

# ── Main ───────────────────────────────────────────────────────────────
def main():
    log("info", "SudoMe daemon starting")
    excluded = get_excluded_users()
    if excluded:
        log("info", f"Auto-revoke excluded users: {', '.join(excluded)}")
    
    # Revoke any orphaned expired grants
    check_expired()
    
    if not HAS_GLIB:
        log("err", "python3-gi not available — cannot run event loop")
        log("err", "Install: sudo apt install python3-gi")
        sys.exit(1)
    
    # ── Signal handlers ──────────────────────────────────────────────
    def sigterm_handler(signum, frame):
        log("info", "Received SIGTERM — shutting down")
        on_shutdown()
        loop.quit()
    
    signal.signal(signal.SIGTERM, sigterm_handler)
    signal.signal(signal.SIGINT, sigterm_handler)
    
    # ── Main loop ────────────────────────────────────────────────────
    loop = GLib.MainLoop()
    
    # Set up D-Bus listeners
    bus = setup_dbus_listeners(loop)
    
    # Periodic expiry check (every CHECK_INTERVAL seconds)
    def periodic_check():
        check_expired()
        return True
    
    GLib.timeout_add_seconds(CHECK_INTERVAL, periodic_check)
    
    log("info", f"Daemon running (checking every {CHECK_INTERVAL}s)")
    
    try:
        loop.run()
    except KeyboardInterrupt:
        on_shutdown()
    
    log("info", "SudoMe daemon stopped")

if __name__ == "__main__":
    main()
