#!/usr/bin/env python3
"""
SudoMe GUI — GTK system tray application for managing temporary sudo access.

Mirrors the SAP Privileges macOS menu bar app: shows current sudo status
in the system tray, allows one-click grant/revoke, and displays countdown
timer when active.

Requirements:
    sudo apt install python3-gi gir1.2-gtk-3.0 gir1.2-appindicator3-0.1
    sudo dnf install python3-gobject gtk3 libappindicator-gtk3
"""

import os
import signal
import subprocess
import sys
import time
from pathlib import Path

try:
    import gi
    gi.require_version("Gtk", "3.0")
    gi.require_version("Notify", "0.7")
    from gi.repository import Gtk, GLib, Notify
    
    # Try AppIndicator3 (Ubuntu ≤ 22.04) then AyatanaAppIndicator3 (Ubuntu 24.04+)
    INDICATOR = None
    try:
        gi.require_version("AppIndicator3", "0.1")
        from gi.repository import AppIndicator3 as IndicatorModule
        INDICATOR = "AppIndicator3"
    except (ValueError, ImportError):
        try:
            gi.require_version("AyatanaAppIndicator3", "0.1")
            from gi.repository import AyatanaAppIndicator3 as IndicatorModule
            INDICATOR = "AyatanaAppIndicator3"
        except (ValueError, ImportError):
            pass
    
    if INDICATOR is None:
        raise ImportError("Neither AppIndicator3 nor AyatanaAppIndicator3 found")
        
except ImportError as e:
    print(f"Missing GTK dependencies. Install with:", file=sys.stderr)
    print("  Ubuntu ≤ 22.04: sudo apt install python3-gi gir1.2-gtk-3.0 gir1.2-appindicator3-0.1 gir1.2-notify-0.7", file=sys.stderr)
    print("  Ubuntu ≥ 24.04: sudo apt install python3-gi gir1.2-gtk-3.0 gir1.2-ayatanaappindicator3-0.1 gir1.2-notify-0.7", file=sys.stderr)
    print(f"Error: {e}", file=sys.stderr)
    sys.exit(1)

VERSION = "2.0.0"
APP_ID = "org.freedesktop.sudome"
PKEXEC = "/usr/bin/pkexec"
HELPER_PATH = "/usr/lib/sudome/sudome-helper"
CONFIG_FILE = "/etc/sudome/config.yaml"


class SudoMeTrayApp:
    """System tray application for SudoMe."""

    def __init__(self):
        self.username = os.environ.get("USER", "")
        self.default_minutes = 30
        self.expiry_ts = 0
        self.indicator = None
        self.menu = None
        self._countdown_timer = None  # GLib source id for 1-second countdown
        
        # Load config defaults
        self._load_config()

        # Initialize notifications
        Notify.init(APP_ID)

        # Create indicator
        self.indicator = IndicatorModule.Indicator.new(
            APP_ID,
            "sudome-inactive",
            IndicatorModule.IndicatorCategory.SYSTEM_SERVICES
        )
        self.indicator.set_status(IndicatorModule.IndicatorStatus.ACTIVE)
        self.indicator.set_attention_icon_full("sudome-expiring", "Sudo expiring soon")
        self.indicator.set_label("", "")

        # Build menu
        self._build_menu()

        # Periodic status refresh (every 10 seconds, lightweight — no pkexec)
        GLib.timeout_add_seconds(10, self._periodic_refresh)

        # Handle SIGINT/SIGTERM
        signal.signal(signal.SIGINT, signal.SIG_DFL)
        signal.signal(signal.SIGTERM, lambda s, f: Gtk.main_quit())

    def _load_config(self):
        """Load defaults from config file."""
        try:
            import yaml
            if os.path.exists(CONFIG_FILE):
                with open(CONFIG_FILE) as f:
                    config = yaml.safe_load(f)
                    self.default_minutes = config.get("default_duration", 30)
        except ImportError:
            pass  # yaml not available, use defaults

    def _build_menu(self):
        """Create the system tray menu."""
        self.menu = Gtk.Menu()

        # Status item (non-interactive)
        self.status_item = Gtk.MenuItem(label="Sudo: checking...")
        self.status_item.set_sensitive(False)
        self.menu.append(self.status_item)

        # Remaining time
        self.time_item = Gtk.MenuItem(label="")
        self.time_item.set_sensitive(False)
        self.menu.append(self.time_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        # Grant sudo
        self.grant_item = Gtk.MenuItem(label=f"SudoMe! ({self.default_minutes} min)")
        self.grant_item.connect("activate", self._on_grant)
        self.menu.append(self.grant_item)

        # Revoke sudo
        self.revoke_item = Gtk.MenuItem(label="Revoke Sudo")
        self.revoke_item.connect("activate", self._on_revoke)
        self.revoke_item.set_sensitive(False)
        self.menu.append(self.revoke_item)

        self.menu.append(Gtk.SeparatorMenuItem())

        # About
        about_item = Gtk.MenuItem(label="About SudoMe")
        about_item.connect("activate", self._on_about)
        self.menu.append(about_item)

        # Quit (restarts to prevent accidental exit)
        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", self._on_quit)
        self.menu.append(quit_item)

        self.indicator.set_menu(self.menu)
        self.menu.show_all()

    def _run_helper(self, action: str, minutes: int = 0, reason: str = "") -> tuple[int, str]:
        """Run the Polkit helper for privileged actions (grant/revoke only)."""
        cmd = [PKEXEC, HELPER_PATH, action, self.username]
        if action == "grant" and minutes > 0:
            cmd.append(str(minutes))
            if reason:
                cmd.append(reason)
        elif action == "revoke" and reason:
            cmd.append(reason)

        try:
            result = subprocess.run(
                cmd, capture_output=True, text=True, timeout=60
            )
            return result.returncode, result.stdout.strip() + result.stderr.strip()
        except Exception as e:
            return 1, str(e)

    def _get_status(self) -> tuple[str, int, int]:
        """Get current sudo status without pkexec (no auth prompt).
        
        Checks 'groups' command (no root needed) and reads state files.
        Returns (state, remaining_seconds, expiry_timestamp)."""
        try:
            # Check if user is in sudo group (no root required)
            result = subprocess.run(
                ["groups", self.username],
                capture_output=True, text=True, timeout=5
            )
            in_sudo = "sudo" in result.stdout
            
            if not in_sudo:
                return "NOT_ACTIVE", 0, 0
            
            # User is in sudo group — check expiry
            state_file = f"/var/lib/sudome/{self.username}.expiry"
            try:
                with open(state_file) as f:
                    expiry = int(f.read().strip())
                now = int(time.time())
                remaining = expiry - now
                if remaining <= 0:
                    return "NOT_ACTIVE", 0, 0
                return "ACTIVE", remaining, expiry
            except (PermissionError, FileNotFoundError, ValueError):
                # Can't read state file (non-root), but user IS in sudo group
                return "ACTIVE", -1, 0
        except Exception:
            return "ERROR", 0, 0

    def _periodic_refresh(self):
        """Periodic refresh of UI state."""
        state, remaining, expiry = self._get_status()
        self._update_ui(state, remaining, expiry)
        return True  # Keep repeating

    def _update_ui(self, state: str, remaining: int, expiry: int):
        """Update menu items and tray icon based on state."""
        if state == "ACTIVE":
            remaining_str = self._format_time(remaining)
            self.status_item.set_label(f"Sudo: ACTIVE")
            self.time_item.set_label(f"  Remaining: {remaining_str}")
            self.time_item.show()

            self.grant_item.set_label("Extend Sudo")
            self.grant_item.set_sensitive(True)
            self.revoke_item.set_sensitive(True)

            # Icon: green or orange if < 5 min
            if remaining <= 300:
                self.indicator.set_icon_full("sudome-expiring", "Sudo expiring soon")
                # Notification at 5 minutes
                if remaining == 300:
                    self._notify("Sudo Expiring Soon", 
                                f"Your sudo access expires in 5 minutes.")
            else:
                self.indicator.set_icon_full("sudome-active", "SudoMe — Active")
            
            self.indicator.set_label(remaining_str, remaining_str)
            self.indicator.set_title(f"SudoMe: {remaining_str}")
            self.expiry_ts = expiry
            self.menu.show_all()

            # Start live countdown if not already running
            self._start_countdown()

        elif state == "NOT_ACTIVE":
            self.status_item.set_label("Sudo: NOT active")
            self.time_item.set_label("")
            self.time_item.hide()

            self.grant_item.set_label(f"SudoMe! ({self.default_minutes} min)")
            self.grant_item.set_sensitive(True)
            self.revoke_item.set_sensitive(False)

            self.indicator.set_icon_full("sudome-inactive", "SudoMe — Not Active")
            self.indicator.set_label("", "")
            self.indicator.set_title("SudoMe: Off")
            self.expiry_ts = 0
            self.menu.show_all()

            # Stop countdown
            self._stop_countdown()

        else:
            self.status_item.set_label(f"Sudo: {state}")
            self.grant_item.set_sensitive(False)
            self.revoke_item.set_sensitive(False)

    def _start_countdown(self):
        """Start 1-second countdown timer if not already running."""
        if self._countdown_timer is None:
            self._countdown_timer = GLib.timeout_add_seconds(1, self._tick_countdown)

    def _stop_countdown(self):
        """Stop the countdown timer."""
        if self._countdown_timer is not None:
            GLib.source_remove(self._countdown_timer)
            self._countdown_timer = None

    def _tick_countdown(self):
        """Update live countdown display every second."""
        if self.expiry_ts <= 0:
            self._stop_countdown()
            return False

        now = int(time.time())
        remaining = self.expiry_ts - now

        if remaining <= 0:
            self.time_item.set_label("  Expired")
            self.indicator.set_label("Expired", "Expired")
            self.indicator.set_title("SudoMe: Expired")
            self._stop_countdown()
            self.menu.show_all()
            # Next periodic refresh will switch to NOT_ACTIVE
            return False

        remaining_str = self._format_time(remaining)
        self.time_item.set_label(f"  Remaining: {remaining_str}")
        self.indicator.set_label(remaining_str, remaining_str)
        self.indicator.set_title(f"SudoMe: {remaining_str}")

        # Switch icon to expiring when < 5 min
        if remaining <= 300 and remaining > 0:
            self.indicator.set_icon_full("sudome-expiring", "Sudo expiring soon")

        self.menu.show_all()
        return True  # Keep timer running

    def _format_time(self, seconds: int) -> str:
        """Format seconds to human-readable string."""
        if seconds <= 0:
            return "expired"
        m, s = divmod(seconds, 60)
        h, m = divmod(m, 60)
        if h > 0:
            return f"{h}h {m}m"
        elif m > 0:
            return f"{m}m {s}s"
        else:
            return f"{s}s"

    def _notify(self, title: str, message: str, urgency: str = "normal"):
        """Show desktop notification."""
        try:
            notification = Notify.Notification.new(title, message, "sudome")
            if urgency == "critical":
                notification.set_urgency(Notify.Urgency.CRITICAL)
            notification.show()
        except Exception:
            pass  # Notifications are non-critical

    def _on_grant(self, _widget):
        """Handle Grant/Extend button click."""
        state, _, _ = self._get_status()

        if state == "ACTIVE":
            # Extend
            self._notify("SudoMe", f"Extending sudo by {self.default_minutes} minutes...")
            ret, output = self._run_helper("grant", self.default_minutes)
            if ret == 0:
                self._notify("SudoMe", f"✓ Sudo extended by {self.default_minutes} minutes")
            else:
                self._notify("SudoMe", f"✗ Failed to extend: {output}", "critical")
        else:
            # Grant
            self._notify("SudoMe", f"Requesting sudo for {self.default_minutes} minutes...")
            ret, output = self._run_helper("grant", self.default_minutes)
            if ret == 0:
                self._notify("SudoMe", f"✓ Sudo granted for {self.default_minutes} minutes")
            else:
                self._notify("SudoMe", f"✗ Failed to grant: {output}", "critical")

        # Force immediate refresh
        state, remaining, expiry = self._get_status()
        self._update_ui(state, remaining, expiry)

    def _on_revoke(self, _widget):
        """Handle Revoke button click."""
        self._notify("SudoMe", "Revoking sudo...")
        ret, output = self._run_helper("revoke")
        if ret == 0 and "REVOKED" in output:
            self._notify("SudoMe", "✓ Sudo revoked. Back to standard user.")
        else:
            self._notify("SudoMe", f"Revoke result: {output}")

        # Force immediate refresh
        state, remaining, expiry = self._get_status()
        self._update_ui(state, remaining, expiry)

    def _on_quit(self, _widget):
        """Restart the app instead of quitting (prevents accidental exit)."""
        self._stop_countdown()
        Gtk.main_quit()
        # exec into a fresh instance
        os.execv(sys.executable, [sys.executable] + sys.argv)

    def _on_about(self, _widget):
        """Show About dialog."""
        dialog = Gtk.AboutDialog()
        dialog.set_program_name("SudoMe")
        dialog.set_version(VERSION)
        dialog.set_comments(
            "Temporary sudo privilege elevation for Linux.\n"
            "Enterprise-ready, Polkit-backed, audit-logged.\n\n"
            "Inspired by SAP Privileges for macOS."
        )
        dialog.set_website("https://github.com/0xEuphonioux/SudoMe")
        dialog.set_license_type(Gtk.License.APACHE_2_0)
        dialog.set_authors(["0xEuphonioux"])
        dialog.set_copyright("Copyright 2026 0xEuphonioux")
        dialog.run()
        dialog.destroy()


def main():
    """Entry point."""
    app = SudoMeTrayApp()
    Gtk.main()


if __name__ == "__main__":
    main()
